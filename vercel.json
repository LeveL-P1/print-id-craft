{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/jobs/process/route.ts": {
      "memory": 2048,
      "maxDuration": 300
    },
    "src/app/api/admin/backup/scheduled/route.ts": {
      "memory": 2048,
      "maxDuration": 60
    },
    "src/app/api/schools/[id]/students/import/route.ts": {
      "memory": 2048,
      "maxDuration": 300
    },
    "src/app/api/schools/[id]/students/bulk-photos/route.ts": {
      "memory": 2048,
      "maxDuration": 300
    },
    "src/app/api/photo-bg/remove/route.ts": {
      "memory": 2048,
      "maxDuration": 300
    },
    "src/app/api/photo-bg/health/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/**/*": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/submit/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    },
    {
      "source": "/(.*)\\.wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/maintenance/cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/jobs/process",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/admin/backup/scheduled",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/photo-bg/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
