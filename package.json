{
  "name": "wisemelon",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "load:submit": "node scripts/load-submit.js",
    "load:full": "node scripts/load-full.js",
    "seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:backfill-student-indexes": "ts-node --project tsconfig.seed.json scripts/backfill-student-indexes.ts",
    "db:prepare-live": "prisma db push && prisma generate && npm run db:backfill-student-indexes",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "db:use:mysql": "node scripts/set-db.js mysql && prisma generate",
    "db:use:postgres": "node scripts/set-db.js postgresql && prisma generate",
    "postinstall": "prisma generate",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:start\"",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:start\"",
    "electron:start": "electron .",
    "desktop:build": "node electron/build-desktop.js",
    "desktop:pack": "npx electron-builder --config electron-builder.config.js --win --dir",
    "desktop:installer": "npx electron-builder --config electron-builder.config.js --win"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "overrides": {
    "glob": "10.5.0",
    "minimatch": "9.0.9"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@imgly/background-removal": "^1.7.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.56.0",
    "@supabase/supabase-js": "^2.99.2",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "konva": "^9.3.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "onnxruntime-web": "1.21.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-image-crop": "^11.0.10",
    "react-konva": "^18.2.10",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "use-image": "^1.1.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
