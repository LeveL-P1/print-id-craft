generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String    @default("")
  role          Role      @default(TEACHER)
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([schoolId])
  @@index([role])
}

enum Role {
  MANUFACTURER
  TEACHER
}

model School {
  id            String       @id @default(cuid())
  name          String
  address       String?
  contactEmail  String       @default("")
  logoUrl       String?
  teachers      User[]
  classes       Class[]
  template      Template?
  students      Student[]
  batches       PrintBatch[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([name])
  @@index([createdAt])
}

model Class {
  id            String    @id @default(cuid())
  name          String
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  linkToken     String    @unique @default(cuid())
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  students      Student[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([schoolId])
  @@index([schoolId, name])
}

model Template {
  id              String      @id @default(cuid())
  schoolId        String      @unique
  school          School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  frontLayout     Json        @default("[]")
  backLayout      Json        @default("[]")
  cardWidthMm     Float       @default(85.6)
  cardHeightMm    Float       @default(54.0)
  printDpi        Int         @default(300)
  orientation     Orientation @default(PORTRAIT)
  fieldConfig     Json        @default("[]")
  templateImageUrl String?
  fieldMappings   Json        @default("[]")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
}

model Student {
  id            String        @id @default(cuid())
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id])
  classId       String
  class         Class         @relation(fields: [classId], references: [id])
  serialNumber  String        @unique
  formData      Json
  photoUrl      String        @default("")
  qrCodeUrl     String?
  status        StudentStatus @default(SUBMITTED)
  flagNote      String?
  submittedAt   DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Compound indexes for high-load query patterns
  @@index([schoolId, status])
  @@index([schoolId, classId])
  @@index([schoolId, classId, status])
  @@index([schoolId, submittedAt])
  @@index([schoolId, serialNumber])
  @@index([classId])
  @@index([status])
}

enum StudentStatus {
  PENDING
  SUBMITTED
  FLAGGED
  APPROVED
  PRINTED
}

model PrintBatch {
  id              String      @id @default(cuid())
  schoolId        String
  school          School      @relation(fields: [schoolId], references: [id])
  studentCount    Int         @default(0)
  frontPdfPath    String?
  backPdfPath     String?
  manifestPath    String?
  status          BatchStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([schoolId])
  @@index([schoolId, status])
}

enum BatchStatus {
  PENDING
  GENERATING
  READY
  DOWNLOADED
}
