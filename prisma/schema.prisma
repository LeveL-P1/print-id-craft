generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String   @default("")
  role         Role     @default(TEACHER)
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  classId      String?
  class        Class?   @relation(fields: [classId], references: [id])
  isMainTeacher Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
  @@index([role])
  @@index([classId])
}

enum Role {
  MANUFACTURER
  TEACHER
}

model School {
  id           String       @id @default(cuid())
  name         String
  address      String?
  contactEmail String       @default("")
  logoUrl      String?
  // School-wide registration link. Parents open one URL and pick their
  // child's class from a dropdown — replaces per-class linkToken sharing.
  linkToken    String       @unique @default(cuid())
  linkActive   Boolean      @default(true)
  linkExpiresAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  template     Template?
  students     Student[]
  classes      Class[]
  teachers     User[]
  batches      PrintBatch[]

  @@index([name])
  @@index([createdAt])
}

model Class {
  id        String   @id @default(cuid())
  name      String
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  linkToken String   @unique @default(cuid())
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  students  Student[]
  teachers  User[]

  @@index([schoolId])
  @@index([schoolId, name])
}

model Template {
  id                   String      @id @default(cuid())
  schoolId             String      @unique
  school               School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  frontLayout          Json        @default("[]")
  backLayout           Json        @default("[]")
  cardWidthMm          Float       @default(85.6)
  cardHeightMm         Float       @default(54.0)
  printDpi             Int         @default(300)
  orientation          Orientation @default(PORTRAIT)
  fieldConfig          Json        @default("[]")
  templateImageUrl     String?
  backTemplateImageUrl String?
  fieldMappings        Json        @default("[]")
  backFieldMappings    Json        @default("[]")
  hasBackSide          Boolean     @default(false)
  photoBgColor         String      @default("#FFFFFF")
  cardSizeLocked       Boolean     @default(false)
  printConfig          Json?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
}

model Student {
  id            String        @id @default(cuid())
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id])
  classId       String
  class         Class         @relation(fields: [classId], references: [id])
  serialNumber  String        @unique
  duplicateFingerprint String?
  fullName      String        @default("")
  normalizedName String      @default("")
  normalizedFatherName String @default("")
  normalizedDob String       @default("")
  normalizedRollNo String    @default("")
  normalizedSearchText String @default("")
  formData      Json
  photoUrl      String        @default("")
  photoPath     String        @default("")
  qrCodeUrl     String?
  status        StudentStatus @default(SUBMITTED)
  flagNote      String?
  teacherComment String?
  submittedAt   DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([schoolId, status])
  @@index([schoolId, classId])
  @@index([schoolId, classId, status])
  @@index([schoolId, submittedAt])
  @@index([schoolId, serialNumber])
  @@index([schoolId, fullName])
  @@index([schoolId, normalizedSearchText])
  @@index([classId])
  @@index([classId, duplicateFingerprint])
  @@index([classId, normalizedRollNo])
  @@index([classId, normalizedName, normalizedFatherName, normalizedDob])
  @@index([status])
  @@index([photoPath])
}

model RateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Job {
  id          String    @id @default(cuid())
  type        JobType
  status      JobStatus @default(PENDING)
  schoolId    String?
  payload     Json?
  result      Json?
  error       String?
  attempts    Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([schoolId, status])
  @@index([type, status])
  @@index([createdAt])
}

model SystemEvent {
  id        String          @id @default(cuid())
  type      SystemEventType
  severity  EventSeverity   @default(INFO)
  message   String
  schoolId  String?
  userId    String?
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([schoolId, createdAt])
}

enum StudentStatus {
  PENDING
  SUBMITTED
  FLAGGED
  APPROVED
  PRINTED
}

model PrintBatch {
  id           String      @id @default(cuid())
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id])
  studentCount Int         @default(0)
  frontPdfPath String?
  backPdfPath  String?
  manifestPath String?
  status       BatchStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([schoolId])
  @@index([schoolId, status])
}

enum BatchStatus {
  PENDING
  GENERATING
  READY
  DOWNLOADED
  FAILED
}

enum JobType {
  IMPORT_STUDENTS
  GENERATE_QR
  GENERATE_PRINT_BATCH
  EXPORT_SCHOOL_ARCHIVE
  EXPORT_PLATFORM_BACKUP
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SystemEventType {
  SUBMIT_FAILED
  UPLOAD_FAILED
  EXPORT_FAILED
  IMPORT_FAILED
  JOB_FAILED
  SECURITY
  MAINTENANCE
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
